# ============================================================
# Code Review Workbench — 环境变量配置
# 复制此文件为 .env 并修改对应值
# ============================================================

# ---- 应用配置 ----
APP_NAME=code-review-workbench
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=change-me-to-a-random-string

# ---- 数据库 ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=code_review
POSTGRES_USER=crw
POSTGRES_PASSWORD=crw_secret

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0

# ---- Milvus 向量数据库 ----
MILVUS_HOST=localhost
MILVUS_PORT=19530

# ---- LLM 配置 (LiteLLM 统一调度) ----
# 智谱AI GLM-5.2（推理模型，OpenAI 兼容接口）
ZHIPU_API_KEY=your-zhipu-api-key-here
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# DeepSeek V4（推理模型，OpenAI 兼容接口）
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 本地模型 (Ollama)
OLLAMA_BASE_URL=http://localhost:11434

# 需要部署的 Ollama 本地模型列表（逗号分隔）
OLLAMA_MODELS=qwen2.5:7b,deepseek-coder:6.7b

# 模型路由规则
# 推理模型（安全审计/架构分析/重构/仲裁）：glm-5.2 或 deepseek-v4
# 工具模型（风格检查/摘要/分块）：ollama/qwen2.5:7b
LLM_REASONING_MODEL=glm-5.2
LLM_UTILITY_MODEL=ollama/qwen2.5:7b

# ---- 代码审查配置 ----
MAX_FILE_SIZE_BYTES=1048576          # 1MB
MAX_FILES_PER_REVIEW=50
REVIEW_TIMEOUT_SECONDS=300
DEFAULT_LANGUAGES=python,go,typescript,javascript

# ---- GitHub/GitLab 集成 ----
GITHUB_TOKEN=ghp_your-token-here
GITLAB_TOKEN=glpat-your-token-here
WEBHOOK_SECRET=your-webhook-secret

# ---- 可观测性 ----
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
PROMETHEUS_METRICS_PORT=9090