# ============================================================
# Code Review Workbench — 环境变量配置
# 复制此文件为 .env 并修改对应值
#
# 重要：
#   - 生产环境（APP_ENV=production）下，所有标记为"敏感"的字段
#     必须配置真实值，不能保留占位符，否则应用启动会失败。
#   - 数据库口令在 docker-compose 中通过 ${VAR:?...}
#     强制要求，缺失会导致容器无法启动。
# ============================================================

# ---- 应用配置 ----
APP_NAME=code-review-workbench
APP_ENV=development
APP_DEBUG=true
# 敏感：生产环境必须改为随机字符串（如 openssl rand -hex 32）
SECRET_KEY=change-me-to-a-random-string

# ---- 数据库 ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=code_review
POSTGRES_USER=crw
# 敏感：生产环境必须改为强口令
POSTGRES_PASSWORD=crw_secret

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0

# ---- LLM 配置 (LiteLLM 统一调度) ----
# 智谱AI GLM-5.2（推理模型，OpenAI 兼容接口）
# 敏感：生产环境必须配置真实 API Key
ZHIPU_API_KEY=your-zhipu-api-key-here
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# DeepSeek V4（推理模型，OpenAI 兼容接口）
# 敏感：生产环境必须配置真实 API Key
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 本地模型 (Ollama)
OLLAMA_BASE_URL=http://localhost:11434

# 需要部署的 Ollama 本地模型列表（逗号分隔）
OLLAMA_MODELS=qwen2.5:7b,deepseek-coder:6.7b

# 模型路由规则
# 推理模型（安全审计/架构分析/重构/仲裁）：glm-5.2 或 deepseek-v4
# 工具模型（风格检查/摘要/分块）：ollama/qwen2.5:7b
LLM_REASONING_MODEL=glm-5.2
LLM_UTILITY_MODEL=ollama/qwen2.5:7b
# Embedding 模型（语义记忆向量检索，智谱 embedding-3 默认 2048 维）
LLM_EMBEDDING_MODEL=glm/embedding-3

# ---- 代码审查配置 ----
MAX_FILE_SIZE_BYTES=1048576          # 1MB
MAX_FILES_PER_REVIEW=50
REVIEW_TIMEOUT_SECONDS=300
DEFAULT_LANGUAGES=python,go,typescript,javascript

# ---- GitHub/GitLab 集成 ----
# GitHub Personal Access Token（用于拉取 PR 代码、回写审查评论）
GITHUB_TOKEN=ghp_your-token-here
# GitLab Personal Access Token
GITLAB_TOKEN=glpat-your-token-here
# 敏感：Webhook 签名密钥，生产环境必须配置真实值
# GitHub: 用于 HMAC-SHA256 签名校验
# GitLab: 作为 X-Gitlab-Token 请求头值
WEBHOOK_SECRET=your-webhook-secret

# ---- CORS 配置 ----
# 生产环境（APP_ENV=production）下，CORS_ORIGINS 必须配置真实域名
# 逗号分隔，如：https://crw.example.com,https://www.crw.example.com
# 开发环境留空则使用默认值 http://localhost:3000,http://127.0.0.1:3000
CORS_ORIGINS=

# ---- 可观测性 ----
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# Prometheus 端口由 docker-compose 固定为 9090，无需在此配置

# ---- Docker 部署 ----
COMPOSE_PROJECT_NAME=crw
